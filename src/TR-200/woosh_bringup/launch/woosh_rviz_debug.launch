<?xml version="1.0"?>

<launch>
  <arg name="robot_ip" default="169.254.128.2" />
  <arg name="robot_port" default="5480" />
  <arg name="robot_identity" default="rviz_debug" />
  <arg name="scene_name" default="" />
  <arg name="map_name" default="" />
  <arg name="topic_prefix" default="/woosh_debug" />
  <arg name="map_frame" default="map" />
  <arg name="publish_hz" default="5.0" />
  <arg name="state_poll_sec" default="1.0" />
  <arg name="scene_refresh_sec" default="5.0" />
  <arg name="launch_rviz" default="true" />
  <arg name="rviz_config" default="$(find woosh_bringup)/rviz/woosh_rviz_debug.rviz" />

  <node pkg="woosh_bringup"
        type="woosh_rviz_debug.py"
        name="woosh_rviz_debug"
        output="screen">
    <param name="robot_ip" value="$(arg robot_ip)" />
    <param name="robot_port" value="$(arg robot_port)" />
    <param name="robot_identity" value="$(arg robot_identity)" />
    <param name="scene_name" value="$(arg scene_name)" />
    <param name="map_name" value="$(arg map_name)" />
    <param name="topic_prefix" value="$(arg topic_prefix)" />
    <param name="map_frame" value="$(arg map_frame)" />
    <param name="publish_hz" value="$(arg publish_hz)" />
    <param name="state_poll_sec" value="$(arg state_poll_sec)" />
    <param name="scene_refresh_sec" value="$(arg scene_refresh_sec)" />
  </node>

  <node if="$(arg launch_rviz)"
        pkg="rviz"
        type="rviz"
        name="woosh_rviz"
        args="-d $(arg rviz_config)"
        output="screen" />
</launch>
