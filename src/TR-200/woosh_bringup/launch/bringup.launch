<?xml version="1.0"?>
<!--
  bringup.launch вҖ” Woosh TR-200 нҶөн•© лёҢл§Ғм—…
  нҸ¬н•Ё мҠӨнғқ:
    1. woosh_sensor_bridge  вҶ’ /scan, /odom_raw, TF(odomвҶ’base_link), TF(base_linkвҶ’laser)
    2. static TF            вҶ’ base_link вҶ’ laser

  мӮ¬мҡ© мҳҲ:
    roslaunch woosh_bringup bringup.launch robot_ip:=169.254.128.2

  Phase 4 (EKF) м Ғмҡ© нӣ„:
    roslaunch woosh_bringup bringup.launch robot_ip:=169.254.128.2 publish_tf:=false
    # вҶ’ sensor_bridge TF л№„нҷңм„ұнҷ”, EKFк°Җ odomвҶ’base_link TF лӢҙлӢ№
-->
<launch>
  <!-- кіөнҶө -->
  <arg name="robot_ip"   default="169.254.128.2" />
  <arg name="robot_port" default="5480" />

  <!-- sensor_bridge мҳөм…ҳ -->
  <arg name="publish_tf"     default="true" />   <!-- Phase 4 EKF мӮ¬мҡ© мӢң false -->
  <arg name="publish_hz"     default="10.0" />
  <arg name="laser_height"   default="0.25" />   <!-- base_linkвҶ’laser z мҳӨн”„м…Ӣ(m) -->

  <!-- 1. Sensor bridge (scan + odom_raw + TF odomвҶ’base_link + TF base_linkвҶ’laser) -->
  <include file="$(find woosh_sensor_bridge)/launch/sensor_bridge.launch">
    <arg name="robot_ip"       value="$(arg robot_ip)" />
    <arg name="robot_port"     value="$(arg robot_port)" />
    <arg name="publish_tf"     value="$(arg publish_tf)" />
    <arg name="publish_hz"     value="$(arg publish_hz)" />
    <arg name="laser_frame"    value="laser" />
  </include>
</launch>
