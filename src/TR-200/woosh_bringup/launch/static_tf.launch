<?xml version="1.0"?>
<!--
  static_tf.launch — 정적 TF 단독 실행용
  base_link → laser (z=0.25m, 회전 없음)

  사용 예:
    roslaunch woosh_bringup static_tf.launch
    roslaunch woosh_bringup static_tf.launch laser_height:=0.30
-->
<launch>
  <!-- 레이저 센서 장착 높이 (m) -->
  <arg name="laser_height" default="0.25" />

  <node pkg="tf2_ros"
        type="static_transform_publisher"
        name="base_link_to_laser"
        args="0 0 $(arg laser_height) 0 0 0 base_link laser" />
</launch>
