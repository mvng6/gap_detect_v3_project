<launch>
  <!-- ============================================================
       save_map.launch вҖ” CartographerлЎң мғқм„ұлҗң м§ҖлҸ„лҘј нҢҢмқјлЎң м ҖмһҘ
       ============================================================
       cartographer.launchк°Җ мӢӨн–ү мӨ‘мқё мғҒнғңм—җм„ң лі„лҸ„ н„°лҜёл„җлЎң мӢӨн–үн•©лӢҲлӢӨ.

       м ҖмһҘ н•ӯлӘ©:
         1. .pgm + .yaml  вҖ” map_saverлҘј нҶөн•ҙ /map нҶ н”Ҫм—җм„ң OccupancyGrid м ҖмһҘ
         2. .pbstream      вҖ” Cartographer лӮҙл¶Җ мғҒнғң м§Ғл ¬нҷ” (pure localizationмҡ©)

       мӢӨн–ү мҳҲмӢң:
         # кё°ліё м ҖмһҘ
         roslaunch woosh_slam_cartographer save_map.launch

         # мқҙлҰ„ м§Җм •
         roslaunch woosh_slam_cartographer save_map.launch map_name:=carto_my_map

         # м ҖмһҘ кІҪлЎң м§Җм •
         roslaunch woosh_slam_cartographer save_map.launch \
           map_name:=carto_my_map \
           output_dir:=/tmp/maps

       м ҖмһҘ кІ°кіј:
         {output_dir}/{map_name}.pgm        вҖ” м җмң  кІ©мһҗ мқҙлҜём§Җ
         {output_dir}/{map_name}.yaml       вҖ” м§ҖлҸ„ л©”нғҖлҚ°мқҙн„° (н•ҙмғҒлҸ„, мӣҗм җ л“ұ)
         {output_dir}/{map_name}.pbstream   вҖ” Cartographer м§Ғл ¬нҷ” мғҒнғң

       нҷңмҡ©:
         AMCL:
           rosrun woosh_bringup woosh_service_driver.py amcl \
             map_file:={output_dir}/{map_name}.yaml

         Cartographer Pure Localization:
           rosrun woosh_bringup woosh_service_driver.py carto_loc \
             state_file:={output_dir}/{map_name}.pbstream
       ============================================================ -->

  <!-- м ҖмһҘн•  м§ҖлҸ„ мқҙлҰ„ (нҷ•мһҘмһҗ м ңмҷё) -->
  <arg name="map_name"    default="carto_woosh_map" />

  <!-- м ҖмһҘ л””л үн„°лҰ¬
       кё°ліёк°’: AMCL/GMapping нҢЁнӮӨм§ҖмҷҖ кіөмң н•ҳлҠ” maps нҸҙлҚ”
       вҶ’ м ҖмһҘ мҰүмӢң amcl.launchмқҳ map_file мқёмһҗлЎң мӮ¬мҡ© к°ҖлҠҘ -->
  <arg name="output_dir"  default="/root/catkin_ws/src/TR-200/woosh_slam/maps" />

  <!-- 1. map_saver: /map нҶ н”Ҫ кө¬лҸ… вҶ’ .pgm + .yaml м ҖмһҘ нӣ„ мһҗлҸҷ мў…лЈҢ -->
  <node pkg="map_server" type="map_saver"
        name="map_saver"
        args="-f $(arg output_dir)/$(arg map_name)"
        output="screen" />

  <!-- 2. .pbstream м ҖмһҘ: finish_trajectory + write_state м„ңл№„мҠӨ нҳём¶ң -->
  <node pkg="woosh_slam_cartographer" type="save_cartographer_state.sh"
        name="save_cartographer_state"
        args="$(arg output_dir)/$(arg map_name).pbstream"
        output="screen" />

</launch>
